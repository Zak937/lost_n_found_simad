rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Items collection rules
    match /items/{itemId} {
      // Allow read access to any authenticated user
      allow read: if request.auth != null;
      
      // Allow creation if the user is authenticated and the 'postedBy' field equals their UID
      allow create: if request.auth != null && request.resource.data.postedBy == request.auth.uid;
      
      // Allow update or delete ONLY if the user is authenticated and they are the one who created it
      allow delete: if request.auth != null && resource.data.postedBy == request.auth.uid;
      
      // Allow update if owner, OR if a Viewer is just updating the status to Claimed_Pending
      // Allow update if owner, OR if a Viewer is just updating the status to Claimed_Pending or Recovered
      allow update: if request.auth != null && (
        resource.data.postedBy == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['itemStatus']) && (request.resource.data.itemStatus == 'Claimed_Pending' || request.resource.data.itemStatus == 'Recovered'))
      );
    }
    
    // Users collection rules
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Verifications sub-collection rules (replaces recoveries)
    match /{path=**}/verifications/{verificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.auth.token.email.matches('.*@simad[.]edu[.]so');
      allow update: if request.auth != null 
                    && (request.auth.uid == resource.data.finderId || request.auth.uid == resource.data.claimantId);
    }
  }
}
